// ============================================================================
// Prisma schema cho QuizzGame
// Phan nay tap trung vao HE THONG DIEM TICH LUY (Points System):
//   - user_points: so du diem hien tai cua tung user (co optimistic locking)
//   - point_transactions: nhat ky (log) tat ca cac thay doi diem, dung de
//     audit, doi soat va debug khi can thiet.
//
// Luu y quan trong:
//   - Diem tich luy la "currency" duy nhat trong game => khong duoc am.
//   - Moi thay doi diem PHAI di kem 1 ban ghi trong point_transactions
//     (atomic trong cung 1 Prisma $transaction) de dam bao co the truy vet.
//   - Truong "version" trong user_points dung cho OPTIMISTIC LOCKING:
//     moi lan update phai kiem tra version cu khop voi DB, neu khong khop
//     (do request khac da cap nhat truoc) thi coi nhu that bai va retry.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Bang luu thong tin nguoi dung (profile) - tao/dong bo khi user dang nhap
/// lan dau qua Firebase Auth. Day la "nguon su that" (source of truth) ve
/// danh tinh nguoi dung trong he thong, tach biet voi Firebase (chi dung de
/// xac thuc dang nhap).
model User {
  id          String   @id @default(uuid())

  /// UID do Firebase Auth cap - duy nhat, dung de doi chieu voi token sau khi xac thuc.
  /// Day la "khoa lien ket" giua he thong cua chung ta va Firebase.
  firebaseUid String   @unique

  /// Ten hien thi (lay tu Firebase, hoac nguoi dung tu chinh sua sau).
  displayName String?

  /// Email - lay tu Firebase Auth (co the null neu dang nhap bang so dien thoai).
  email       String?  @unique

  /// So dien thoai - lay tu Firebase Auth (co the null neu dang nhap bang email).
  phone       String?

  /// Ten truong THPT - nguoi dung tu khai bao trong qua trinh onboarding.
  school      String?

  /// Tinh/thanh pho - phuc vu thong ke khu vuc & xep hang theo dia phuong (tinh nang sau).
  province    String?

  /// Danh sach MA mon hoc da dang ky on thi (vi du: ["TOAN", "VAN", "ANH"]).
  /// Dung kieu mang String[] cua Postgres - Prisma ho tro truc tiep.
  /// QUY UOC: chi luu MA mon (id), KHONG luu ten hien thi - tranh trung lap
  /// du lieu; ten hien thi duoc tra ve tu danh sach hang so o tang ung dung
  /// (xem `SUBJECT_CATALOG` trong `users.types.ts`).
  subjects    String[] @default([])

  /// URL anh dai dien (tuong doi, vi du /uploads/avatars/<userId>.jpg).
  /// null = chua upload, FE hien thi avatar chu cai thay the.
  avatarUrl   String?

  /// Thoi diem dang nhap gan nhat - cap nhat moi lan goi POST /api/auth/login
  /// thanh cong. Phuc vu thong ke "user hoat dong" va debug (vi du phat hien
  /// tai khoan "ma" lau ngay khong dung).
  lastLoginAt DateTime?

  /// Thoi diem tao tai khoan - khong doi sau khi tao.
  createdAt   DateTime @default(now())

  /// Co tai khoan bi khoa boi admin hay khong.
  /// true = bi khoa, moi request cua user nay se bi tu choi voi HTTP 403.
  isBlocked   Boolean  @default(false)

  /// Vai tro cua nguoi dung trong he thong: "STUDENT" hoac "ADMIN".
  /// STUDENT: hoc sinh binh thuong. ADMIN: co quyen quan tri he thong.
  role        String   @default("STUDENT")

  wrongAnswers  WrongAnswer[]
  notifications Notification[]
  submissions   StudentQuestionSubmission[]

  /// Index ho tro filter nhanh theo trang thai khoa va vai tro trong admin panel.
  @@index([isBlocked])
  @@index([role])
  @@map("users")
}

/// Bang luu so du diem tich luy hien tai cua tung nguoi dung.
/// Moi user chi co DUY NHAT 1 ban ghi (quan he 1-1 thong qua userId).
model UserPoints {
  id            String   @id @default(uuid())

  /// ID cua user (lien ket voi he thong Auth - Firebase Auth UID duoc luu o bang User rieng,
  /// o day dung String de tuong thich voi UID dang chuoi cua Firebase).
  userId        String   @unique

  /// So diem tich luy hien tai. Mac dinh = 0 khi tao user moi.
  /// RANG BUOC NGHIEP VU: khong duoc phep < 0 (kiem tra o tang ung dung
  /// truoc khi ghi, vi Prisma/Postgres khong ho tro CHECK constraint
  /// truc tiep qua schema mot cach don gian & portable).
  currentPoints Int      @default(0)

  /// Phien ban ban ghi - dung cho OPTIMISTIC LOCKING.
  /// Moi lan UPDATE thanh cong se tang version len 1.
  /// Neu 2 request cung doc version=5 va cung muon update,
  /// chi 1 trong 2 thanh cong (vi WHERE version = 5 chi dung 1 lan),
  /// request con lai phai doc lai va thu lai (retry).
  version       Int      @default(0)

  /// Thoi diem cap nhat gan nhat - tu dong cap nhat moi khi ban ghi thay doi.
  lastUpdated   DateTime @updatedAt

  @@map("user_points")
}

/// Bang nhat ky (log) cho MOI thay doi diem trong he thong.
/// Day la nguon "su that" (source of truth) de doi soat, audit, va
/// giai quyet khieu nai cua nguoi choi (vi du: "tai sao toi bi tru diem?").
model PointTransaction {
  id        String   @id @default(uuid())

  /// ID cua user bi anh huong boi giao dich nay.
  userId    String

  /// So diem thay doi: duong (+) la cong diem, am (-) la tru diem.
  /// Vi du: +1 (dung cau hoi tap), -60 (vao thi thu), +120 (dat 10 diem thi thu).
  delta     Int

  /// Ly do thay doi diem - dang chuoi co dinh (enum-like) de de truy van/thong ke.
  /// Vi du: "ON_TAP_CORRECT", "THI_THU_ENTRY_FEE", "THI_THU_RESULT_BONUS",
  ///        "PVP_WIN", "PVP_LOSE", "PVP_LOCK_BET", "TRANSFER_IN", "TRANSFER_OUT", v.v.
  reason    String

  /// Du lieu bo sung dang JSON, linh hoat theo tung loai giao dich.
  /// Vi du: { "examId": "...", "score": 8.5 } hoac { "matchId": "...", "opponentId": "..." }
  metadata  Json?

  /// Thoi diem giao dich duoc tao - khong doi sau khi tao (immutable log).
  createdAt DateTime @default(now())

  // Index theo userId + createdAt giup truy van lich su giao dich cua 1 user
  // theo thu tu thoi gian (phan trang) duoc nhanh hon dang ke.
  @@index([userId, createdAt])
  @@map("point_transactions")
}

// ============================================================================
// MODULE ON TAP (Practice Module)
// ============================================================================

/// Bang cau hoi on thi THPT - nguon du lieu chinh cho che do On tap va Thi thu.
model Question {
  id            String   @id @default(uuid())
  /// Ma mon hoc (vi du: "TOAN", "VAN", "ANH") - khop voi SUBJECT_CATALOG.
  subject       String
  /// Ten chuong/chu de (tuy chon) - dung de nhom cau hoi khi thong ke.
  chapter       String?
  /// Do kho: 1=de, 2=trung binh, 3=kho.
  difficulty    Int
  /// Noi dung cau hoi.
  question      String
  /// 4 lua chon tra loi dang JSON mang 4 phan tu string.
  options       Json
  /// Chi so dap an dung (0-3) tuong ung voi vi tri trong mang options.
  correctAnswer Int
  /// Giai thich sau khi tra loi (tuy chon) - hien thi sau khi user nop dap an.
  explanation   String?
  /// Nam de thi (tuy chon) - vi du 2023, 2024.
  examYear      Int?
  /// Ma de thi (tuy chon) - vi du "De 1", "Ma de 101".
  examCode      String?
  /// Trang thai kich hoat - false neu bi an (soft delete hoac bi bao cao nhieu).
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  wrongAnswers  WrongAnswer[]

  @@index([subject, difficulty, isActive])
  @@map("questions")
}

/// Bang luu thong tin tung phien on tap (moi lan user nhan "Bat dau on tap").
model PracticeSession {
  id           String    @id @default(uuid())
  /// ID cua user thuc hien phien on tap.
  userId       String
  /// Ma mon hoc da chon on tap.
  subjectId    String
  /// Danh sach 15 questionId da rut ngau nhien cho phien nay.
  questions    Json
  /// So cau dung sau khi hoan thanh (mac dinh 0 truoc khi complete).
  score        Int       @default(0)
  /// So diem tich luy duoc trong phien nay (= score vi moi cau dung = 1 diem).
  pointsEarned Int       @default(0)
  startedAt    DateTime  @default(now())
  /// null = chua hoan thanh; co gia tri = da hoan thanh (hoac het gio).
  completedAt  DateTime?

  @@index([userId, completedAt])
  @@map("practice_sessions")
}

/// Bang luu tung cau tra loi cua user trong 1 phien on tap.
/// Tach rieng kho JSON tren PracticeSession de tranh race condition
/// khi nhieu request cung update mang JSON dong thoi.
model PracticeAnswer {
  id             String   @id @default(uuid())
  sessionId      String
  questionId     String
  /// Chi so lua chon (0-3). null = chua tra loi (dat cho du lieu tuong lai).
  selectedOption Int?
  isCorrect      Boolean
  answeredAt     DateTime @default(now())

  /// Rang buoc UNIQUE dam bao idempotency: goi lai POST /practice/answer
  /// cung sessionId + questionId se tra ve ket qua cu, KHONG insert them.
  @@unique([sessionId, questionId])
  @@map("practice_answers")
}

/// Bang lich su cau hoi da lam cua tung user - dung de filter cau "chua lam
/// trong 24h" khi rut cau hoi cho phien moi. Tach rieng de query nhanh bang index.
model UserQuestionHistory {
  id          String   @id @default(uuid())
  userId      String
  questionId  String
  /// Thoi diem lam cau hoi gan nhat (cap nhat neu lam lai).
  attemptedAt DateTime @default(now())

  @@index([userId, attemptedAt])
  /// Moi user chi co 1 ban ghi moi cau hoi; khi lam lai thi update attemptedAt.
  @@unique([userId, questionId])
  @@map("user_question_history")
}

/// Bang bao cao cau hoi sai/co van de tu phia nguoi dung.
/// Khi >= 5 bao cao PENDING cung 1 cau thi tu dong an cau do (isActive = false).
model QuestionReport {
  id          String   @id @default(uuid())
  questionId  String
  userId      String
  /// Ly do bao cao: WRONG_ANSWER | BAD_CONTENT | TYPO | OTHER
  reason      String
  /// Mo ta them (tuy chon) do user nhap.
  description String?
  /// Trang thai xu ly: PENDING | REVIEWED | FIXED | DISMISSED
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  /// User co the bao cao lai 1 cau da tung bao cao NEU report truoc do da duoc xu ly
  /// xong (FIXED/DISMISSED) - chi chan khi con PENDING. Rang buoc "toi da 1 report
  /// PENDING / user / cau hoi" duoc ap dung bang PARTIAL UNIQUE INDEX rieng (khong
  /// the khai bao truc tiep trong Prisma schema) - xem migration
  /// `20260714000000_report_resubmit_after_resolved`.
  @@index([userId, questionId])
  @@index([status, createdAt])
  @@map("question_reports")
}

/// Ban ghi luu SNAPSHOT noi dung cau hoi TRUOC khi admin sua (qua trang xu ly bao cao).
/// Dung de audit/khoi phuc neu can - moi lan sua tao 1 ban ghi moi (khong ghi de).
model QuestionEditHistory {
  id          String   @id @default(uuid())

  /// ID cau hoi (bang questions) bi sua.
  questionId  String

  /// ID bao cao dan den lan sua nay (tuy chon - null neu sua khong qua luong bao cao,
  /// de ngo cho truong hop admin sua truc tiep tu noi khac trong tuong lai).
  reportId    String?

  /// Toan bo du lieu cau hoi TRUOC khi sua, dang JSON (snapshot toan bo cac field
  /// cua model Question tai thoi diem sua: subject, chapter, difficulty, question,
  /// options, correctAnswer, explanation, examYear, examCode, isActive).
  beforeData  Json

  createdAt   DateTime @default(now())

  /// Truy van lich su sua theo tung cau hoi, moi nhat truoc.
  @@index([questionId, createdAt])
  @@map("question_edit_history")
}

// ============================================================================
// NGAN HANG CAU HOI (Question Bank)
// ============================================================================

/// Bang luu kho cau hoi chung cho module Thi thu.
/// Tach rieng khoi bang questions (On tap) — hai he thong doc lap.
/// Admin quan ly tap trung tai day; khi tao de thi co the "lay cau tu kho"
/// thay vi nhap tay tung cau. Xoa khoi kho la HARD DELETE (co canh bao).
model QuestionBank {
  id            String   @id @default(uuid())

  /// Ma mon hoc (vi du: "TOAN", "VAN", "ANH") - khop voi SUBJECT_CATALOG.
  subject       String

  /// Ten chuong/chu de (tuy chon) - dung de loc khi chon cau vao de thi.
  chapter       String?

  /// Do kho: 1=de, 2=trung binh, 3=kho.
  difficulty    Int

  /// Dang cau hoi: MCQ_4 | TRUE_FALSE_4 | FILL_BLANK (giong ExamQuestion).
  questionType  String

  /// So diem cua cau hoi.
  points        Float

  /// Noi dung cau hoi.
  questionText  String

  /// Du lieu lua chon/phat bieu dang JSON (null voi FILL_BLANK).
  options       Json?

  /// Dap an dung dang JSON (so, mang boolean, hoac mang string).
  correctAnswer Json

  /// Giai thich sau khi tra loi (tuy chon).
  explanation   String?

  /// Nam de thi goc (tuy chon).
  examYear      Int?

  /// Ma de thi goc (tuy chon).
  examCode      String?

  /// Trang thai kich hoat — false neu bi an tam (soft delete).
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())

  /// ID cau hoi goc tu bang questions (module On tap) — chi dung boi seed script.
  /// null = cau hoi duoc tao thu cong hoac nhap qua Excel.
  /// @unique dam bao seed script idempotent: chay nhieu lan khong tao duplicate.
  sourceQuestionId String? @unique

  /// Cac ExamQuestion tham chieu den cau hoi nay.
  examQuestions ExamQuestion[]

  /// Cac StudentQuestionSubmission da duoc duyet va tao ra ban ghi nay.
  /// Thong thuong chi co 1 submission tro toi 1 ban ghi QuestionBank, nhung
  /// khong ep @unique o day de tranh rang buoc thua — logic nghiep vu (approve)
  /// dam bao quan he 1-1 tren thuc te.
  submissions   StudentQuestionSubmission[]

  @@index([subject, difficulty, isActive])
  @@map("question_bank")
}

// ============================================================================
// MODULE QUAN LY CAU HOI — HOC SINH DONG GOP (Student Question Submissions)
// ============================================================================

/// Bang luu cau hoi trac nghiem do HOC SINH tu gui len de dong gop vao kho.
/// Luong: hoc sinh gui (PENDING) -> admin duyet (APPROVED, tao QuestionBank entry
/// + thuong 30 diem) hoac tu choi (REJECTED, kem ly do). Khi cau da duoc duyet va
/// dung trong 1 de thi that, hoc sinh nhan them 5 diem/lan (toi da 100 diem/cau).
model StudentQuestionSubmission {
  id                 String   @id @default(uuid())

  /// ID hoc sinh gui cau hoi.
  userId             String

  /// Ma mon hoc (khop SUBJECT_CATALOG).
  subject            String

  /// Ten chuong/chu de (tuy chon).
  chapter            String?

  /// Dang cau hoi: MCQ_4 | TRUE_FALSE_4 | FILL_BLANK (giong ExamQuestion/QuestionBank).
  questionType       String   @default("MCQ_4")

  /// Noi dung cau hoi hoc sinh nhap.
  questionText       String

  /// Du lieu lua chon/phat bieu dang JSON (null voi FILL_BLANK) - giong QuestionBank.options.
  options            Json?

  /// Dap an dung dang JSON (so cho MCQ_4, mang boolean cho TRUE_FALSE_4,
  /// mang string cho FILL_BLANK) - giong QuestionBank.correctAnswer.
  correctAnswer      Json

  /// Trang thai xu ly: PENDING (cho duyet) | APPROVED (da duyet) | REJECTED (tu choi).
  status             String   @default("PENDING")

  /// Ghi chu cua admin — bat buoc khi tu choi (ly do), tuy chon khi duyet.
  adminNote          String?

  /// ID ban ghi QuestionBank duoc tao ra sau khi duyet (null khi con PENDING/REJECTED).
  questionBankId     String?

  /// Lien ket voi ban ghi QuestionBank tuong ung (chi co gia tri sau khi duyet).
  questionBank       QuestionBank? @relation(fields: [questionBankId], references: [id])

  /// So lan cau hoi (sau khi duyet) da duoc them vao 1 de thi that.
  usageCount         Int      @default(0)

  /// Tong diem thuong "usage" hoc sinh da nhan tu cau hoi nay (toi da 100).
  usagePointsEarned  Int      @default(0)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Truy van chinh: danh sach cau da gui cua 1 hoc sinh theo trang thai, moi nhat truoc;
  /// dong thoi dung de dem rate limit 5 cau/ngay (WHERE userId=? AND createdAt >= startOfDay).
  @@index([userId, status, createdAt])
  /// Tra cuu nguoc tu QuestionBank -> submission goc (dung trong usage points trigger).
  @@index([questionBankId])
  @@map("student_question_submissions")
}

// ============================================================================
// MODULE THI THU (Mock Exam Module)
// ============================================================================

/// Bang luu thong tin 1 de thi thu - do admin tao, gom nhieu cau hoi (ExamQuestion).
model ExamPaper {
  id              String   @id @default(uuid())

  /// Ma mon hoc (vi du: "TOAN", "VAN") - khop voi SUBJECT_CATALOG.
  subject         String

  /// Ten de thi - vi du "De thi thu THPT QG 2024 - Mon Toan - De 101".
  title           String

  /// Thoi gian lam bai (phut) - dung de tinh han nop bai (xem ExamSession.durationMinutes).
  durationMinutes Int

  /// Trang thai kich hoat - false neu admin tam an de (khong duoc rut khi chon de ngau nhien).
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())

  @@index([subject, isActive])
  @@map("exam_papers")
}

/// Bang luu tung cau hoi trong 1 de thi thu - ho tro 3 dang: MCQ_4, TRUE_FALSE_4, FILL_BLANK.
model ExamQuestion {
  id            String   @id @default(uuid())

  /// De thi ma cau hoi nay thuoc ve.
  examPaperId   String

  /// Ten chuong/chu de (tuy chon) - dung de phan tich ket qua theo chuong sau khi nop bai.
  chapter       String?

  /// Do kho: 1=de, 2=trung binh, 3=kho.
  difficulty    Int

  /// Dang cau hoi:
  ///   - "MCQ_4": trac nghiem 4 lua chon, chon 1 dap an dung
  ///   - "TRUE_FALSE_4": 4 phat bieu dung/sai (a/b/c/d)
  ///   - "FILL_BLANK": dien dap an dang tu do
  questionType  String

  /// So diem cua cau hoi nay trong de. Tong diem cac cau KHONG can bang 10 -
  /// he thong tu quy doi diem dat duoc ve thang 10 khi cham bai (xem exam.service.ts).
  points        Float

  /// Noi dung cau hoi.
  questionText  String

  /// Du lieu lua chon/phat bieu dang JSON, theo tung dang:
  ///   - MCQ_4: mang 4 string (lua chon A-D)
  ///   - TRUE_FALSE_4: mang 4 string (4 phat bieu a/b/c/d)
  ///   - FILL_BLANK: null (khong co lua chon)
  options       Json?

  /// Dap an dung dang JSON, theo tung dang:
  ///   - MCQ_4: so (0-3) - chi so lua chon dung trong `options`
  ///   - TRUE_FALSE_4: mang 4 boolean - dung/sai cho tung phat bieu a/b/c/d
  ///   - FILL_BLANK: mang string - cac dap an duoc chap nhan (chi can khop 1 trong mang)
  correctAnswer Json

  /// Giai thich (tuy chon) - hien thi trong trang ket qua sau khi nop bai.
  explanation   String?

  /// Nam de thi goc (tuy chon) - vi du 2023, 2024.
  examYear      Int?

  /// Ma de thi goc (tuy chon) - vi du "Ma de 101" (phan biet voi ExamPaper.id noi bo).
  examCode      String?

  /// ID cua cau hoi trong Ngan hang cau hoi (tuy chon).
  /// null = cau hoi duoc nhap tay (hoac qua Excel import).
  /// co gia tri = cau hoi duoc lay tu kho, van giu ban ghi goc trong QuestionBank.
  questionBankId String?

  /// Lien ket voi QuestionBank (tuy chon - nullable).
  questionBank   QuestionBank? @relation(fields: [questionBankId], references: [id])

  /// Trang thai kich hoat - false neu bi an (soft delete).
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())

  wrongAnswers  WrongAnswer[]

  @@index([examPaperId, isActive])
  @@index([questionBankId])
  @@map("exam_questions")
}

/// Bang luu thong tin 1 phien thi thu (moi lan user bam "Thi thu" va duoc rut 1 de ngau nhien).
model ExamSession {
  id              String    @id @default(uuid())

  /// ID nguoi dung lam bai.
  userId          String

  /// De thi duoc rut cho phien nay.
  examPaperId     String

  /// Ma mon hoc da chon thi thu (dung de thong ke, doc lap voi ExamPaper.subject ve sau).
  subjectId       String

  /// Thoi gian lam bai (phut) - SNAPSHOT tu ExamPaper.durationMinutes tai thoi diem bat dau,
  /// de neu admin sua de sau do se khong anh huong den cac phien dang dien ra.
  durationMinutes Int

  startedAt       DateTime  @default(now())

  /// Trang thai: "IN_PROGRESS" (dang lam) | "COMPLETED" (da nop, da cham diem)
  /// | "EXPIRED" (qua gio nop bai, khong duoc cham diem)
  /// | "ABANDONED" (nguoi dung chu dong huy phien qua nut Thoat).
  status          String    @default("IN_PROGRESS")

  /// Diem so theo thang 10 (1 chu so thap phan) - null khi chua nop bai/het gio.
  score           Float?

  /// So diem tich luy duoc thuong them tu ket qua thi (0 neu score < 7.0 - khong cong diem).
  pointsAwarded   Int       @default(0)

  completedAt     DateTime?

  // Index theo (userId, examPaperId) phuc vu thuat toan chon de cong bang
  // (dem so lan user da thi tung de). Index theo (userId, completedAt) phuc vu lich su.
  @@index([userId, examPaperId])
  @@index([userId, completedAt])
  @@map("exam_sessions")
}

/// Bang luu tung cau tra loi cua user trong 1 phien thi thu.
model ExamAnswer {
  id             String   @id @default(uuid())

  sessionId      String

  examQuestionId String

  /// Dap an user da chon/nhap khi nop bai, dang JSON theo tung dang cau hoi:
  ///   - MCQ_4: so (0-3) hoac null neu chua chon
  ///   - TRUE_FALSE_4: mang 4 boolean|null - y chua chon tinh la sai
  ///   - FILL_BLANK: string (co the rong neu chua dien)
  selectedAnswer Json

  /// So diem cau nay dat duoc - co the la so le (vi du TRUE_FALSE_4 dung 2/4 y).
  pointsEarned   Float    @default(0)

  answeredAt     DateTime @default(now())

  /// Moi cau hoi trong 1 phien chi co 1 ban ghi tra loi.
  @@unique([sessionId, examQuestionId])
  @@map("exam_answers")
}

// ============================================================================
// MODULE ON CAU SAI (Wrong Answer Review)
// ============================================================================

/// Bang luu cau hoi da tra loi sai cua tung user — tu ca On tap lan Thi thu.
/// Moi (userId, questionId) hoac (userId, examQuestionId) chi co 1 ban ghi;
/// khi cung cau do sai lan nua thi upsert: tang wrongCount, cap nhat thoi gian.
/// Ban ghi tu dong "het han" sau 14 ngay ke tu lan sai gan nhat (expiresAt).
model WrongAnswer {
  id             Int      @id @default(autoincrement())

  /// ID nguoi dung bi sai cau nay.
  userId         String

  /// FK den Question (module On tap) — null neu day la cau sai tu Thi thu.
  questionId     String?

  /// FK den ExamQuestion (module Thi thu) — null neu day la cau sai tu On tap.
  examQuestionId String?

  /// So lan da sai cau nay (cong don, reset ve 1 khi xoa het han va sai lai).
  wrongCount     Int      @default(1)

  /// Thoi diem sai gan nhat — moi lan sai them thi cap nhat.
  lastWrongAt    DateTime @default(now())

  /// Thoi diem het han = lastWrongAt + 14 ngay. Query chi lay ban ghi con han.
  expiresAt      DateTime

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  question       Question?     @relation(fields: [questionId], references: [id], onDelete: SetNull)
  examQuestion   ExamQuestion? @relation(fields: [examQuestionId], references: [id], onDelete: SetNull)

  /// Dam bao moi user chi co 1 ban ghi moi cau On tap.
  @@unique([userId, questionId])
  /// Dam bao moi user chi co 1 ban ghi moi cau Thi thu.
  @@unique([userId, examQuestionId])
  /// Toc do query chinh: lay cau sai chua het han cua 1 user (WHERE userId=? AND expiresAt>NOW()).
  @@index([userId, expiresAt])
  @@map("wrong_answers")
}

// ============================================================================
// MODULE THONG BAO (Notifications)
// ============================================================================

/// Loai thong bao — xac dinh nguon tao va muc tieu dieu huong.
enum NotificationType {
  /// Dat moc streak hoc lien tuc (7/14/30/60/100 ngay).
  STREAK_MILESTONE
  /// Thu hang leaderboard tang sau khi nop bai thi.
  RANK_UP
  /// Thu hang leaderboard giam sau khi nop bai thi.
  RANK_DOWN
  /// Admin da xu ly bao cao cau hoi cua hoc sinh (duyet hoac tu choi).
  REPORT_RESOLVED
  /// De thi moi duoc kich hoat (active) cho mon hoc ma hoc sinh da tung thi.
  NEW_EXAM_PAPER
  /// Cau hoi hoc sinh gui duoc admin duyet (vao ngan hang + thuong diem).
  SUBMISSION_APPROVED
  /// Cau hoi hoc sinh gui bi admin tu choi (kem ly do).
  SUBMISSION_REJECTED
  /// Cau hoi hoc sinh gui duoc dung trong 1 de thi (thuong them diem usage).
  SUBMISSION_USED
}

/// Bang luu thong bao cho tung nguoi dung.
/// Moi su kien quan trong (streak, hang, bao cao, de moi) tao 1 ban ghi o day.
/// Frontend polling moi 30s de lay so luong chua doc va hien toast/badge.
model Notification {
  id           String           @id @default(uuid())

  /// ID nguoi dung nhan thong bao.
  userId       String

  /// Loai thong bao — xac dinh icon, mau sac va muc tieu dieu huong.
  type         NotificationType

  /// Tieu de ngan (hien tren badge/toast).
  title        String

  /// Noi dung day du cua thong bao.
  body         String

  /// Da doc chua — false khi moi tao, true khi user bam doc.
  isRead       Boolean          @default(false)

  /// Man hinh dich khi bam vao thong bao: "progress" | "leaderboard" | "exam" | null.
  targetScreen String?

  /// Du lieu bo sung dang JSON (streakDays, rankBefore/After, subjectName...).
  metadata     Json?

  createdAt    DateTime         @default(now())

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Query chinh: danh sach thong bao cua user theo thu tu moi nhat, loc chua doc.
  @@index([userId, isRead, createdAt])
  @@map("notifications")
}
