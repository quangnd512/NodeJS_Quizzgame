// ============================================================================
// Prisma schema cho QuizzGame
// Phan nay tap trung vao HE THONG DIEM TICH LUY (Points System):
//   - user_points: so du diem hien tai cua tung user (co optimistic locking)
//   - point_transactions: nhat ky (log) tat ca cac thay doi diem, dung de
//     audit, doi soat va debug khi can thiet.
//
// Luu y quan trong:
//   - Diem tich luy la "currency" duy nhat trong game => khong duoc am.
//   - Moi thay doi diem PHAI di kem 1 ban ghi trong point_transactions
//     (atomic trong cung 1 Prisma $transaction) de dam bao co the truy vet.
//   - Truong "version" trong user_points dung cho OPTIMISTIC LOCKING:
//     moi lan update phai kiem tra version cu khop voi DB, neu khong khop
//     (do request khac da cap nhat truoc) thi coi nhu that bai va retry.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Bang luu thong tin nguoi dung (profile) - tao/dong bo khi user dang nhap
/// lan dau qua Firebase Auth. Day la "nguon su that" (source of truth) ve
/// danh tinh nguoi dung trong he thong, tach biet voi Firebase (chi dung de
/// xac thuc dang nhap).
model User {
  id          String   @id @default(uuid())

  /// UID do Firebase Auth cap - duy nhat, dung de doi chieu voi token sau khi xac thuc.
  /// Day la "khoa lien ket" giua he thong cua chung ta va Firebase.
  firebaseUid String   @unique

  /// Ten hien thi (lay tu Firebase, hoac nguoi dung tu chinh sua sau).
  displayName String?

  /// Email - lay tu Firebase Auth (co the null neu dang nhap bang so dien thoai).
  email       String?  @unique

  /// So dien thoai - lay tu Firebase Auth (co the null neu dang nhap bang email).
  phone       String?

  /// Ten truong THPT - nguoi dung tu khai bao trong qua trinh onboarding.
  school      String?

  /// Tinh/thanh pho - phuc vu thong ke khu vuc & xep hang theo dia phuong (tinh nang sau).
  province    String?

  /// Danh sach MA mon hoc da dang ky on thi (vi du: ["TOAN", "VAN", "ANH"]).
  /// Dung kieu mang String[] cua Postgres - Prisma ho tro truc tiep.
  /// QUY UOC: chi luu MA mon (id), KHONG luu ten hien thi - tranh trung lap
  /// du lieu; ten hien thi duoc tra ve tu danh sach hang so o tang ung dung
  /// (xem `SUBJECT_CATALOG` trong `users.types.ts`).
  subjects    String[] @default([])

  /// Thoi diem dang nhap gan nhat - cap nhat moi lan goi POST /api/auth/login
  /// thanh cong. Phuc vu thong ke "user hoat dong" va debug (vi du phat hien
  /// tai khoan "ma" lau ngay khong dung).
  lastLoginAt DateTime?

  /// Thoi diem tao tai khoan - khong doi sau khi tao.
  createdAt   DateTime @default(now())

  @@map("users")
}

/// Bang luu so du diem tich luy hien tai cua tung nguoi dung.
/// Moi user chi co DUY NHAT 1 ban ghi (quan he 1-1 thong qua userId).
model UserPoints {
  id            String   @id @default(uuid())

  /// ID cua user (lien ket voi he thong Auth - Firebase Auth UID duoc luu o bang User rieng,
  /// o day dung String de tuong thich voi UID dang chuoi cua Firebase).
  userId        String   @unique

  /// So diem tich luy hien tai. Mac dinh = 0 khi tao user moi.
  /// RANG BUOC NGHIEP VU: khong duoc phep < 0 (kiem tra o tang ung dung
  /// truoc khi ghi, vi Prisma/Postgres khong ho tro CHECK constraint
  /// truc tiep qua schema mot cach don gian & portable).
  currentPoints Int      @default(0)

  /// Phien ban ban ghi - dung cho OPTIMISTIC LOCKING.
  /// Moi lan UPDATE thanh cong se tang version len 1.
  /// Neu 2 request cung doc version=5 va cung muon update,
  /// chi 1 trong 2 thanh cong (vi WHERE version = 5 chi dung 1 lan),
  /// request con lai phai doc lai va thu lai (retry).
  version       Int      @default(0)

  /// Thoi diem cap nhat gan nhat - tu dong cap nhat moi khi ban ghi thay doi.
  lastUpdated   DateTime @updatedAt

  @@map("user_points")
}

/// Bang nhat ky (log) cho MOI thay doi diem trong he thong.
/// Day la nguon "su that" (source of truth) de doi soat, audit, va
/// giai quyet khieu nai cua nguoi choi (vi du: "tai sao toi bi tru diem?").
model PointTransaction {
  id        String   @id @default(uuid())

  /// ID cua user bi anh huong boi giao dich nay.
  userId    String

  /// So diem thay doi: duong (+) la cong diem, am (-) la tru diem.
  /// Vi du: +1 (dung cau hoi tap), -60 (vao thi thu), +120 (dat 10 diem thi thu).
  delta     Int

  /// Ly do thay doi diem - dang chuoi co dinh (enum-like) de de truy van/thong ke.
  /// Vi du: "ON_TAP_CORRECT", "THI_THU_ENTRY_FEE", "THI_THU_RESULT_BONUS",
  ///        "PVP_WIN", "PVP_LOSE", "PVP_LOCK_BET", "TRANSFER_IN", "TRANSFER_OUT", v.v.
  reason    String

  /// Du lieu bo sung dang JSON, linh hoat theo tung loai giao dich.
  /// Vi du: { "examId": "...", "score": 8.5 } hoac { "matchId": "...", "opponentId": "..." }
  metadata  Json?

  /// Thoi diem giao dich duoc tao - khong doi sau khi tao (immutable log).
  createdAt DateTime @default(now())

  // Index theo userId + createdAt giup truy van lich su giao dich cua 1 user
  // theo thu tu thoi gian (phan trang) duoc nhanh hon dang ke.
  @@index([userId, createdAt])
  @@map("point_transactions")
}

// ============================================================================
// MODULE ON TAP (Practice Module)
// ============================================================================

/// Bang cau hoi on thi THPT - nguon du lieu chinh cho che do On tap va Thi thu.
model Question {
  id            String   @id @default(uuid())
  /// Ma mon hoc (vi du: "TOAN", "VAN", "ANH") - khop voi SUBJECT_CATALOG.
  subject       String
  /// Ten chuong/chu de (tuy chon) - dung de nhom cau hoi khi thong ke.
  chapter       String?
  /// Do kho: 1=de, 2=trung binh, 3=kho.
  difficulty    Int
  /// Noi dung cau hoi.
  question      String
  /// 4 lua chon tra loi dang JSON mang 4 phan tu string.
  options       Json
  /// Chi so dap an dung (0-3) tuong ung voi vi tri trong mang options.
  correctAnswer Int
  /// Giai thich sau khi tra loi (tuy chon) - hien thi sau khi user nop dap an.
  explanation   String?
  /// Nam de thi (tuy chon) - vi du 2023, 2024.
  examYear      Int?
  /// Ma de thi (tuy chon) - vi du "De 1", "Ma de 101".
  examCode      String?
  /// Trang thai kich hoat - false neu bi an (soft delete hoac bi bao cao nhieu).
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([subject, difficulty, isActive])
  @@map("questions")
}

/// Bang luu thong tin tung phien on tap (moi lan user nhan "Bat dau on tap").
model PracticeSession {
  id           String    @id @default(uuid())
  /// ID cua user thuc hien phien on tap.
  userId       String
  /// Ma mon hoc da chon on tap.
  subjectId    String
  /// Danh sach 15 questionId da rut ngau nhien cho phien nay.
  questions    Json
  /// So cau dung sau khi hoan thanh (mac dinh 0 truoc khi complete).
  score        Int       @default(0)
  /// So diem tich luy duoc trong phien nay (= score vi moi cau dung = 1 diem).
  pointsEarned Int       @default(0)
  startedAt    DateTime  @default(now())
  /// null = chua hoan thanh; co gia tri = da hoan thanh (hoac het gio).
  completedAt  DateTime?

  @@index([userId, completedAt])
  @@map("practice_sessions")
}

/// Bang luu tung cau tra loi cua user trong 1 phien on tap.
/// Tach rieng kho JSON tren PracticeSession de tranh race condition
/// khi nhieu request cung update mang JSON dong thoi.
model PracticeAnswer {
  id             String   @id @default(uuid())
  sessionId      String
  questionId     String
  /// Chi so lua chon (0-3). null = chua tra loi (dat cho du lieu tuong lai).
  selectedOption Int?
  isCorrect      Boolean
  answeredAt     DateTime @default(now())

  /// Rang buoc UNIQUE dam bao idempotency: goi lai POST /practice/answer
  /// cung sessionId + questionId se tra ve ket qua cu, KHONG insert them.
  @@unique([sessionId, questionId])
  @@map("practice_answers")
}

/// Bang lich su cau hoi da lam cua tung user - dung de filter cau "chua lam
/// trong 24h" khi rut cau hoi cho phien moi. Tach rieng de query nhanh bang index.
model UserQuestionHistory {
  id          String   @id @default(uuid())
  userId      String
  questionId  String
  /// Thoi diem lam cau hoi gan nhat (cap nhat neu lam lai).
  attemptedAt DateTime @default(now())

  @@index([userId, attemptedAt])
  /// Moi user chi co 1 ban ghi moi cau hoi; khi lam lai thi update attemptedAt.
  @@unique([userId, questionId])
  @@map("user_question_history")
}

/// Bang bao cao cau hoi sai/co van de tu phia nguoi dung.
/// Khi >= 5 bao cao PENDING cung 1 cau thi tu dong an cau do (isActive = false).
model QuestionReport {
  id          String   @id @default(uuid())
  questionId  String
  userId      String
  /// Ly do bao cao: WRONG_ANSWER | BAD_CONTENT | TYPO | OTHER
  reason      String
  /// Mo ta them (tuy chon) do user nhap.
  description String?
  /// Trang thai xu ly: PENDING | REVIEWED | FIXED | DISMISSED
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  /// Moi user chi bao cao 1 lan moi cau hoi.
  @@unique([userId, questionId])
  @@index([status, createdAt])
  @@map("question_reports")
}

// ============================================================================
// MODULE THI THU (Mock Exam Module)
// ============================================================================

/// Bang luu thong tin 1 de thi thu - do admin tao, gom nhieu cau hoi (ExamQuestion).
model ExamPaper {
  id              String   @id @default(uuid())

  /// Ma mon hoc (vi du: "TOAN", "VAN") - khop voi SUBJECT_CATALOG.
  subject         String

  /// Ten de thi - vi du "De thi thu THPT QG 2024 - Mon Toan - De 101".
  title           String

  /// Thoi gian lam bai (phut) - dung de tinh han nop bai (xem ExamSession.durationMinutes).
  durationMinutes Int

  /// Trang thai kich hoat - false neu admin tam an de (khong duoc rut khi chon de ngau nhien).
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())

  @@index([subject, isActive])
  @@map("exam_papers")
}

/// Bang luu tung cau hoi trong 1 de thi thu - ho tro 3 dang: MCQ_4, TRUE_FALSE_4, FILL_BLANK.
model ExamQuestion {
  id            String   @id @default(uuid())

  /// De thi ma cau hoi nay thuoc ve.
  examPaperId   String

  /// Ten chuong/chu de (tuy chon) - dung de phan tich ket qua theo chuong sau khi nop bai.
  chapter       String?

  /// Do kho: 1=de, 2=trung binh, 3=kho.
  difficulty    Int

  /// Dang cau hoi:
  ///   - "MCQ_4": trac nghiem 4 lua chon, chon 1 dap an dung
  ///   - "TRUE_FALSE_4": 4 phat bieu dung/sai (a/b/c/d)
  ///   - "FILL_BLANK": dien dap an dang tu do
  questionType  String

  /// So diem cua cau hoi nay trong de. Tong diem cac cau KHONG can bang 10 -
  /// he thong tu quy doi diem dat duoc ve thang 10 khi cham bai (xem exam.service.ts).
  points        Float

  /// Noi dung cau hoi.
  questionText  String

  /// Du lieu lua chon/phat bieu dang JSON, theo tung dang:
  ///   - MCQ_4: mang 4 string (lua chon A-D)
  ///   - TRUE_FALSE_4: mang 4 string (4 phat bieu a/b/c/d)
  ///   - FILL_BLANK: null (khong co lua chon)
  options       Json?

  /// Dap an dung dang JSON, theo tung dang:
  ///   - MCQ_4: so (0-3) - chi so lua chon dung trong `options`
  ///   - TRUE_FALSE_4: mang 4 boolean - dung/sai cho tung phat bieu a/b/c/d
  ///   - FILL_BLANK: mang string - cac dap an duoc chap nhan (chi can khop 1 trong mang)
  correctAnswer Json

  /// Giai thich (tuy chon) - hien thi trong trang ket qua sau khi nop bai.
  explanation   String?

  /// Nam de thi goc (tuy chon) - vi du 2023, 2024.
  examYear      Int?

  /// Ma de thi goc (tuy chon) - vi du "Ma de 101" (phan biet voi ExamPaper.id noi bo).
  examCode      String?

  /// Trang thai kich hoat - false neu bi an (soft delete).
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())

  @@index([examPaperId, isActive])
  @@map("exam_questions")
}

/// Bang luu thong tin 1 phien thi thu (moi lan user bam "Thi thu" va duoc rut 1 de ngau nhien).
model ExamSession {
  id              String    @id @default(uuid())

  /// ID nguoi dung lam bai.
  userId          String

  /// De thi duoc rut cho phien nay.
  examPaperId     String

  /// Ma mon hoc da chon thi thu (dung de thong ke, doc lap voi ExamPaper.subject ve sau).
  subjectId       String

  /// Thoi gian lam bai (phut) - SNAPSHOT tu ExamPaper.durationMinutes tai thoi diem bat dau,
  /// de neu admin sua de sau do se khong anh huong den cac phien dang dien ra.
  durationMinutes Int

  startedAt       DateTime  @default(now())

  /// Trang thai: "IN_PROGRESS" (dang lam) | "COMPLETED" (da nop, da cham diem)
  /// | "EXPIRED" (qua gio nop bai, khong duoc cham diem).
  status          String    @default("IN_PROGRESS")

  /// Diem so theo thang 10 (1 chu so thap phan) - null khi chua nop bai/het gio.
  score           Float?

  /// So diem tich luy duoc thuong them tu ket qua thi (0 neu score < 7.0 - khong cong diem).
  pointsAwarded   Int       @default(0)

  completedAt     DateTime?

  // Index theo (userId, examPaperId) phuc vu thuat toan chon de cong bang
  // (dem so lan user da thi tung de). Index theo (userId, completedAt) phuc vu lich su.
  @@index([userId, examPaperId])
  @@index([userId, completedAt])
  @@map("exam_sessions")
}

/// Bang luu tung cau tra loi cua user trong 1 phien thi thu.
model ExamAnswer {
  id             String   @id @default(uuid())

  sessionId      String

  examQuestionId String

  /// Dap an user da chon/nhap khi nop bai, dang JSON theo tung dang cau hoi:
  ///   - MCQ_4: so (0-3) hoac null neu chua chon
  ///   - TRUE_FALSE_4: mang 4 boolean|null - y chua chon tinh la sai
  ///   - FILL_BLANK: string (co the rong neu chua dien)
  selectedAnswer Json

  /// So diem cau nay dat duoc - co the la so le (vi du TRUE_FALSE_4 dung 2/4 y).
  pointsEarned   Float    @default(0)

  answeredAt     DateTime @default(now())

  /// Moi cau hoi trong 1 phien chi co 1 ban ghi tra loi.
  @@unique([sessionId, examQuestionId])
  @@map("exam_answers")
}
