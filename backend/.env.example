# Sao chep file nay thanh ".env" va dien gia tri that truoc khi chay du an.
# KHONG BAO GIO commit file ".env" that len Git (da duoc khai bao trong .gitignore).

# Chuoi ket noi PostgreSQL - dinh dang: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quizzgame?schema=public"

# Cong chay backend Express (mac dinh 4000 neu khong khai bao)
PORT=4000
